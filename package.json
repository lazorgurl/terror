{
  "name": "terror-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build tsconfig.build.json --watch",
    "lint": "eslint 'packages/*/src/**/*.ts' && prettier --check 'packages/*/src/**/*.ts'",
    "test": "vitest run",
    "clean": "tsc --build tsconfig.build.json --clean && rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
