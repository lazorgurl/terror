{
  "name": "terror-monorepo",
  "private": true,
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build tsconfig.build.json --watch",
    "lint": "eslint 'packages/*/src/**/*.ts' && prettier --check 'packages/*/src/**/*.ts'",
    "test": "vitest run",
    "clean": "tsc --build tsconfig.build.json --clean && rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
